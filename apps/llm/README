# C++ LLM Application
#
# End-to-end text generation using the Backpack public API (backpack.h).
# Supports all architectures (Phi-4, Qwen, LLaMA, etc.) in GGUF and ONNX,
# plus non-standard architectures (LFM2 conv+MoE) via generic ONNX.
#
# ─── Build ────────────────────────────────────────────────────────────────
#
#   cd gitignore/runtime/build
#   cmake ../../../runtime
#   cmake --build . --config Release
#
# This produces:
#   backpack_llm       - LLM application (this app)
#   backpack_runtime   - Low-level CLI (advanced profiling/benchmarks)
#   backpack.lib       - Static library (for custom apps)
#
# ─── Usage ────────────────────────────────────────────────────────────────
#
# Chat with Phi-4 (ONNX):
#   ./Release/backpack_llm --model E:/ai-models/phi-4/ --chat "What is 2+2?"
#
# Raw prompt:
#   ./Release/backpack_llm --model models/qwen-3/ --prompt "Once upon a time"
#
# Benchmark:
#   ./Release/backpack_llm --model models/phi-4/ --benchmark
#
# Save baseline performance:
#   ./Release/backpack_llm --model models/phi-4/ --save-baseline
#   ./Release/backpack_llm --model models/phi-4/ --save-baseline results.json
#
# All options:
#   --model <path>       Model path (GGUF file, GGUF dir, or ONNX dir)
#   --prompt <text>      Raw text prompt
#   --chat <message>     Chat message (auto-wrapped in ChatML template)
#   --max-tokens <n>     Max tokens to generate (default: 100)
#   --backend <name>     GPU backend: vulkan, d3d12, metal
#   --format <fmt>       Force model format: gguf / onnx
#   --benchmark          Run prefill+decode benchmark
#   --profile            Enable GPU timestamp profiling
#   --save-baseline [path]  Save benchmark to JSON (default: baseline.json)
#
# ─── API Quick Start ──────────────────────────────────────────────────────
#
#   #include "backpack.h"
#
#   auto* model = bp_model_load("models/phi-4/");
#   auto* ctx   = bp_context_create(model);
#   bp_generate(ctx, "Hello!", {.maxTokens = 50},
#       [](const std::string& t) { printf("%s", t.c_str()); return true; });
#   bp_context_free(ctx);
#   bp_model_free(model);
